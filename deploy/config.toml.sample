[polymarket]
# Polymarket configuration
# 
# 1. Private key - obtain it from https://reveal.magic.link/polymarket
private_key = "0x8d3d049e3714bc5fe4bcf6d0e990326445be3381615e6e25648b2e81ef2edf21"
# 
# 2. Smart Wallet address - view it at polymarket.com/settings (the address holding funds)
wallet_address = "0x85B634AA874fd6a5E1a80ec9a64fDAbb395201D4"
#
# API credentials are derived automatically; no manual configuration is required.

# Gamma API base URL
base_url = "https://gamma-api.polymarket.com"

# Python order service URL (orders are submitted through this service)
order_service_url = "http://127.0.0.1:8001"

# The [settings] and [auto_trade] configuration has moved to the database.
# It can be changed in real time through the frontend without restarting the service.
# The following are initial defaults, written to the database at first startup.

[settings]
# Data refresh interval (seconds)
refresh_interval = 5
# Minimum profit margin (%) for displaying arbitrage opportunities
min_profit_margin = 1.0
# Default amount (USD) used for arbitrage calculations
default_bet_amount = 10.0
# Profit-margin threshold (%) for starting tracking
tracking_threshold = 2.0

[auth]
# Login authentication configuration
username = "admin"
password = "DACsxc8531@@"
# JWT key (change this to a random string)
secret_key = "your-secret-key-change-this-in-production-min-32-chars-long"
# Token expiration time (hours)
token_expire_hours = 24

[auto_trade]
# Automated trading is disabled by default
enabled = false
# Maximum amount (USD) per automated trade
max_amount = 10.0
# Maximum number of automated trades
max_trade_count = 2
# Arbitrage opportunity duration threshold (milliseconds)
min_duration_ms = 500


[telegram]
# Telegram notification configuration (automated-trade notifications)
# Disabled by default; enable when needed.
enabled = true

# Telegram Bot Token (obtain it from @BotFather)
bot_token = "8534665491:AAEYBT3ZQC-N63ThwwGRCUNQT0BP6_OZlqI"

# Telegram Chat ID (group or channel ID)
# To obtain it, add the bot to a group, send a message, then visit
# https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates
chat_id = "-1003242331044"