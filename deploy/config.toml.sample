[polymarket]
# Polymarket 配置（Magic Link 用户只需配置这两项）
# 
# 1. 私钥 - 从 https://reveal.magic.link/polymarket 获取
private_key = "0x8d3d049e3714bc5fe4bcf6d0e990326445be3381615e6e25648b2e81ef2edf21"
# 
# 2. Smart Wallet 地址 - 从 polymarket.com/settings 查看（资金存放地址）
wallet_address = "0x85B634AA874fd6a5E1a80ec9a64fDAbb395201D4"
#
# API 凭据会自动派生，无需手动配置

# Gamma API 基础 URL
base_url = "https://gamma-api.polymarket.com"

# CLOB API URL
clob_url = "https://clob.polymarket.com"

# 签名类型（1 = Magic Link 用户）
signature_type = 1

# 以下字段为自动派生的 API 凭据，留空即可
api_key = ""
api_secret = ""
api_passphrase = ""

[settings]
# 刷新间隔（秒）
refresh_interval = 5
# 最小利润率（百分比）
min_profit_margin = 2.0
# 默认下注金额（美元）
default_bet_amount = 100.0

[auth]
# 登录认证配置
username = "admin"
password = "admin123"
# JWT 密钥（请修改为随机字符串）
secret_key = "your-secret-key-change-this-in-production-min-32-chars-long"
# Token 过期时间（小时）
token_expire_hours = 24
