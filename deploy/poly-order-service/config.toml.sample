# Polymarket 下单服务配置
# 
# 此配置文件用于 Python 下单服务
# 包含 Polymarket 账户凭据

[polymarket]
# 私钥 - 从 https://reveal.magic.link/polymarket 获取
private_key = "0x8d3d049e3714bc5fe4bcf6d0e990326445be3381615e6e25648b2e81ef2edf21"

# Smart Wallet 地址 - 从 polymarket.com/settings 查看
wallet_address = "0x85B634AA874fd6a5E1a80ec9a64fDAbb395201D4"

# CLOB API URL
clob_url = "https://clob.polymarket.com"

# 签名类型（1 = Magic Link 用户）
signature_type = 1
